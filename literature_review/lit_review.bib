  year        = {2025},
  eprint      = {2503.01074},
  eprinttype  = {arXiv},
  url         = {https://github.com/umfieldrobotics/OceanSim},
  urldate     = {2026-05-21},
  annotation  = {Brings underwater simulation onto NVIDIA Isaac Sim /
                 Omniverse, with GPU ray tracing and a USD asset
                 pipeline. Lead group: Field Robotics Group (FRoG),
                 University of Michigan; PI Katherine~A.~Skinner.
                 Apache-2.0; very active (v4.5 released Sept~2025,
                 Isaac Sim~5.0 compatible). The strongest current
                 candidate for vectorized ML training in marine
                 perception. Underwater-only today, but the
                 underlying engine extends naturally to surface,
                 aerial, and terrestrial assets.},
}

