% it relevant, and the community signals that justify inclusion.
%
% URLs and last-accessed dates are recorded so future contributors
% can verify the snapshot we relied on.

% --------------------------------------------------------------------
% Substrate
% --------------------------------------------------------------------

@inproceedings{koenig2004gazebo,
  author      = {Koenig, Nathan and Howard, Andrew},
  title       = {Design and Use Paradigms for {Gazebo}, an Open-Source Multi-Robot Simulator},
  booktitle   = {Proc.\ {IEEE/RSJ} Int.\ Conf.\ on Intelligent Robots and Systems ({IROS})},
  year        = {2004},
  pages       = {2149--2154},
  address     = {Sendai, Japan},
  doi         = {10.1109/IROS.2004.1389727},
  url         = {https://github.com/gazebosim/gz-sim},
  urldate     = {2026-05-21},
  annotation  = {Founding paper for Gazebo, now maintained by Open
                 Robotics (post-Ignition rename). Modern Gazebo
                 (Garden, Harmonic, Jetty) is the substrate beneath
                 VRX, DAVE, and LRAUV. Gazebo Classic reached
                 end-of-life Jan~2025. Apache-2.0; very active
                 community via gazebosim.org forum, Discord, monthly
                 community meetings. Included as the de-facto open
                 substrate for ROS-based marine simulation.},
}

